{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals"],
    "noEmit": true,
    "paths": {
      "#electron/*": ["./electron/*"]
    }
  },
  "include": ["src/**/*", "electron/**/*"]
}
